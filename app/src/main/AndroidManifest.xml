<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-feature android:name="android.hardware.type.watch" android:required="true" />

    <!-- WAKE_LOCK: Required by the Wear OS watch face service to keep the CPU awake
         during complication data updates. Provenance: base_0.apk → uses-permission. -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- RECEIVE_COMPLICATION_DATA: Required for WFF 4 ComplicationSlot data binding.
         Provenance: WFF 4 spec — mandatory for any watch face using ComplicationSlot.
         Reference: https://developer.android.com/training/wearables/wff/complication -->
    <uses-permission android:name="com.google.android.wearable.permission.RECEIVE_COMPLICATION_DATA" />

    <!-- BODY_SENSORS: Required for heart-rate complication (Slot 6 default=HEART_RATE)
         and step-count complication (Slot 0 default=STEP_COUNT).
         Provenance: base_0.apk → uses-permission. -->
    <uses-permission android:name="android.permission.BODY_SENSORS" />

    <!-- ACTIVITY_RECOGNITION: Required for step-count data provider on Android 10+.
         Provenance: base_0.apk → uses-permission. -->
    <uses-permission android:name="android.permission.ACTIVITY_RECOGNITION" />

    <application
        android:label="@string/app_name"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher"
        android:hasCode="false"
        android:allowBackup="false">

        <meta-data
            android:name="com.google.android.wearable.standalone"
            android:value="true" />

        <meta-data
            android:name="com.google.android.wearable.watchface.clock_type"
            android:value="DIGITAL" />

        <!-- WFF version 4 targets Wear OS 6 (API 36). -->
        <property
            android:name="com.google.wear.watchface.format.version"
            android:value="4" />

        <!-- Tells the system to use the declarative WFF configuration -->
        <meta-data
            android:name="com.google.android.wearable.watchface.wearableConfigurationAction"
            android:value="com.google.android.wearable.watchface.CONFIG_WFF" />

        <!-- Links to the preview and category metadata -->
        <meta-data
            android:name="com.google.android.wearable.watchface.format"
            android:resource="@xml/watch_face_info" />

        <meta-data
            android:name="com.google.android.wearable.watchface.preview"
            android:resource="@drawable/preview_image" />

        <meta-data
            android:name="com.google.android.wearable.watchface.preview_circular"
            android:resource="@drawable/preview_image" />

    </application>

</manifest>
